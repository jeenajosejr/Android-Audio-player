<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/gradiant_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:text="Equalizer"
        android:textSize="20sp"
        android:textColor="#fff"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <LinearLayout
        android:id="@+id/bandContainer"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:orientation="horizontal"
        android:weightSum="5"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="20dp">

        <LinearLayout
            android:orientation="vertical"
            android:layout_margin="20dp"
            android:layout_width="match_parent"
            android:layout_gravity="center"
            android:layout_height="wrap_content">

            <Button android:id="@+id/btnFlat" android:text="Flat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <Button android:id="@+id/btnRock" android:text="Rock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <Button android:id="@+id/btnJazz" android:text="Jazz"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <Button android:id="@+id/btnClassical" android:text="Classical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <Button android:id="@+id/btnPop" android:text="Pop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <Button android:id="@+id/btnVocal" android:text="Vocal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>